{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ReClip",
  "version": "1.1.0",
  "identifier": "com.reclip.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ReClip",
        "width": 800,
        "height": 600,
        "transparent": true,
        "decorations": false,
        "shadow": true,
        "visible": false
      },
      {
        "label": "quick",
        "title": "Quick Menu",
        "width": 320,
        "height": 450,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https: data: blob:; font-src 'self' data: https:; connect-src 'self' https: http://localhost:*; media-src 'self' asset:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$RESOURCE/**"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/gameticharles/ReClip/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNDNzgwNUJGNzcxQTU2MzYKUldRMlZocDN2d1Y0UEl2NFBORVBSUStTZkFNeGl1SUxXUExLRE1Ob2xPbUJuN3RaQk5XS0VxdjIK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "publisher": "Charles Gameti",
    "copyright": "© 2026 Rein Tech Services",
    "shortDescription": "Intelligent Clipboard Manager",
    "longDescription": "ReClip is a powerful cross-platform clipboard history manager with rich content preview, OCR, code snippets, templates, and more.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}